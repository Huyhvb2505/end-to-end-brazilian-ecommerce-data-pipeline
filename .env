# Spark E-Commerce Bootcamp Environment Configuration
# Copy this to .env and customize as needed

# ========================================
# PostgreSQL Configuration
# ========================================
POSTGRES_USER=spark_user
POSTGRES_PASSWORD=spark_password
POSTGRES_DB=ecommerce_analytics
POSTGRES_PORT=5432

# ========================================
# Spark Configuration
# ========================================
SPARK_MASTER_PORT=7077
SPARK_MASTER_WEBUI_PORT=8080
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2
SPARK_EXECUTOR_MEMORY=1G
SPARK_DRIVER_MEMORY=1G

# ========================================
# Jupyter Configuration
# ========================================
JUPYTER_PORT=8888
JUPYTER_TOKEN=
# Leave empty for no token/password

# ========================================
# MinIO Configuration
# ========================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ========================================
# Application Configuration
# ========================================
# Number of customers to generate
NUM_CUSTOMERS=10000

# Number of products to generate
NUM_PRODUCTS=1000

# Number of transactions to generate
NUM_TRANSACTIONS=100000

# Data generation seed (for reproducibility)
RANDOM_SEED=42

# ========================================
# Advanced Spark Settings (Optional)
# ========================================
# SPARK_ADAPTIVE_ENABLED=true
# SPARK_SHUFFLE_PARTITIONS=200
# SPARK_SQL_WAREHOUSE_DIR=/opt/spark-warehouse

